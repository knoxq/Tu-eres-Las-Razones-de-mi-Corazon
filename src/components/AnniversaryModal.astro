<div class="anniv-overlay" id="anniv-modal" aria-hidden="true">
  <div class="anniv-card">
    <div class="anniv-hearts">💝</div>
    <h1 class="anniv-title">Felices 1 año y 6 meses</h1>
    <p class="anniv-text">
      Gracias por todo lo vivido miamor y por todo lo que nos falta vivir juntos, se que ha sido bastante dificil ultimamente las cosas pero te juro que eso no ha hecho que te ame menos, de hecho, te amo mucho mas de lo que imaginas. Espero disfrutes de este libro, esta hecho con mucho amor y dedicado todo para ti. Te amo mucho mi niña preciosa
    </p>
    <button class="anniv-btn" id="anniv-close" type="button">Cerrar</button>
  </div>
</div>

<style>
  .anniv-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(13, 11, 30, 0.72);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .anniv-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .anniv-card {
    text-align: center;
    padding: 2.5rem 2rem;
    max-width: 500px;
    width: 90%;
    background: linear-gradient(145deg, #1a1626, #241a3a);
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(183, 162, 208, 0.2);
    transform: translateY(16px);
    transition: transform 0.3s ease;
  }

  .anniv-overlay.active .anniv-card {
    transform: translateY(0);
  }

  .anniv-hearts {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .anniv-title {
    font-family: 'Lilita One', sans-serif;
    font-size: 2rem;
    color: #b7a2d0;
    margin: 0 0 1.2rem;
    text-shadow: 0 0 20px rgba(183, 162, 208, 0.3);
  }

  .anniv-text {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    line-height: 1.8;
    color: #d4cde0;
    margin: 0 0 1.8rem;
    text-align: justify;
  }

  .anniv-btn {
    padding: 0.7rem 2.5rem;
    border: none;
    border-radius: 30px;
    background: linear-gradient(135deg, #6a4a9a, #4a6fa5);
    color: white;
    font-family: 'Quicksand', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .anniv-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(106, 74, 154, 0.5);
  }

  .anniv-btn:active {
    transform: scale(0.98);
  }

  @media (max-width: 480px) {
    .anniv-card { padding: 2rem 1.5rem; }
    .anniv-title { font-size: 1.6rem; }
    .anniv-text { font-size: 0.9rem; }
  }
</style>

<script>
  const RELEASE = new Date('2026-07-03T00:00:00-06:00').getTime();
  const WINDOW_END = RELEASE + 2 * 24 * 60 * 60 * 1000;
  const ADMIN_KEY = 'dd-amor-2026';
  const STORAGE_KEY = 'anniv-modal-closed';

  function shouldShow() {
    const now = Date.now();
    const inWindow = now >= RELEASE && now < WINDOW_END;
    const isAdmin = new URLSearchParams(window.location.search).get('access') === ADMIN_KEY;
    return (inWindow || isAdmin) && (isAdmin || sessionStorage.getItem(STORAGE_KEY) !== '1');
  }

  function closeModal(modal) {
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    if (!isAdminAccess()) sessionStorage.setItem(STORAGE_KEY, '1');
  }

  function isAdminAccess() {
    return new URLSearchParams(window.location.search).get('access') === ADMIN_KEY;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('anniv-modal');
    if (!modal) return;
    if (!shouldShow()) return;

    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');

    const closeBtn = document.getElementById('anniv-close');
    closeBtn?.addEventListener('click', () => closeModal(modal));

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal(modal);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) closeModal(modal);
    });
  });
</script>