---
---

<div class="modal-backdrop" id="envelope-modal">
  <div class="envelope-wrapper">
    <button class="close-modal-btn" id="close-envelope-btn">✕</button>

    <div class="envelope-container" id="envelope-box">
      <div class="envelope-back"></div>
      <div class="envelope-flap" id="envelope-flap"></div>

      <div class="letter-card" id="letter-card">
        <div class="letter-stamp">💝</div>
        <div class="letter-header">Un Capítulo Especial Para Ti...</div>
        <div class="letter-number" id="letter-reason-num">Capítulo #...</div>
        <div class="letter-body" id="letter-reason-text">
          "Me enamoré de ti porque..."
        </div>
        <div class="letter-footer">Te amo con todo mi corazón.</div>
        <button class="letter-fav-btn" id="letter-fav-toggle">
          <span class="heart-icon">❤️</span> Guardar en favoritas
        </button>
      </div>

      <div class="envelope-front"></div>
    </div>

    <div class="envelope-hint" id="envelope-hint">¡Haz clic en el sobre para abrir la carta!</div>
  </div>
</div>
