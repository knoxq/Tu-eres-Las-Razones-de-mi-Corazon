<div class="book-progress">
  <div class="progress-bar-track">
    <div class="progress-bar-fill" id="progress-fill" style="width: 0%;"></div>
  </div>
  <span class="progress-text" id="progress-label">0 de 12 razones vistas</span>
</div>

<div class="pagination-controls">
  <button class="pag-btn" id="prev-page-btn" aria-label="Página anterior">
    <span class="arrow">◀</span> Atrás
  </button>
  <span class="page-indicator" id="page-indicator-text">Página 1 de 25</span>
  <button class="pag-btn" id="next-page-btn" aria-label="Siguiente página">
    Siguiente <span class="arrow">▶</span>
  </button>
</div>
